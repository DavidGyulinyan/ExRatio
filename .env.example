# Copy to .env for local development (never commit .env).
# For EAS production builds, set the same names as project secrets:
#   eas secret:create --scope project --name EXPO_PUBLIC_API_KEY --value "..." --type string

# Exchange rates (required)
EXPO_PUBLIC_API_URL=https://v6.exchangerate-api.com/v6/
EXPO_PUBLIC_API_KEY=

# Supabase (required for sign-in / sync)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: stable OAuth / email confirmation redirect (HTTPS or app scheme)
# EXPO_PUBLIC_AUTH_EMAIL_REDIRECT=https://your-domain.com/auth/callback

# Optional: override native build numbers (EAS production auto-increments versionCode)
# ANDROID_VERSION_CODE=1
# IOS_BUILD_NUMBER=1
